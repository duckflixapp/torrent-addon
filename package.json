{
    "name": "torrent-addon",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "duckflix-addon-build --manifest",
        "pack": "bun run build && rm -rf release && mkdir -p release/torrent-addon && cp dist/index.js dist/manifest.json release/torrent-addon/ && cd release && zip -r torrent-addon.zip torrent-addon"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "prettier": "3.8.3"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@duckflixapp/addon-sdk": "0.2.1",
        "axios": "^1.16.0"
    },
    "version": "0.0.1"
}
